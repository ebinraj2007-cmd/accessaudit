# Copy to .env and fill in before exposing AccessAudit beyond localhost.
ACCESSAUDIT_TOKEN=            # operator bearer token (openssl rand -hex 32)
ACCESSAUDIT_ORIGINS=http://localhost:8010,http://127.0.0.1:8010
ACCESSAUDIT_MAX_UPLOAD=5242880   # max upload bytes (5 MB)
ACCESSAUDIT_RATE=120             # per-IP requests/min
ACCESSAUDIT_RATE_STRICT=15       # per-IP requests/min on uploads/sample/clear
ACCESSAUDIT_LOG_LEVEL=INFO
